{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "shogun-ai",
  "version": "0.1.0",
  "identifier": "ai.shogun.desktop",
  "build": {
    "frontendDist": "../web-dist",
    "devUrl": "http://127.0.0.1:4173/SHOGUN%20Hi-Fi%20UI.html",
    "beforeDevCommand": "python3 -m http.server 4173 --bind 127.0.0.1",
    "beforeBuildCommand": "npm run build:web-dist"
  },
  "app": {
    "windows": [
      {
        "title": "SHOGUN AI",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
