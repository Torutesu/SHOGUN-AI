# SHOGUN Memory Layer — Environment Variables
# Copy this file to .env and fill in your values.

# ============================================================
# Embeddings (Optional — keyword search works without this)
# ============================================================
OPENAI_API_KEY=

# ============================================================
# LLM (Optional — enables query expansion and entity extraction)
# ============================================================
ANTHROPIC_API_KEY=

# ============================================================
# Supabase (Cloud sync — optional, works offline without)
# ============================================================
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Clerk Authentication (Optional for local-only use)
# ============================================================
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ============================================================
# Stripe Billing
# ============================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_TEAM_PRICE_ID=

# ============================================================
# Email (Resend)
# ============================================================
RESEND_API_KEY=

# ============================================================
# Analytics & Monitoring
# ============================================================
POSTHOG_API_KEY=
SENTRY_DSN=

# ============================================================
# Storage
# ============================================================
SHOGUN_DATA_DIR=./pgdata

# ============================================================
# Privacy
# ============================================================
SHOGUN_PII_REMOVAL=true

# ============================================================
# Logging
# ============================================================
SHOGUN_LOG_LEVEL=info
