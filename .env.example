# SHOGUN Memory Layer — Environment Variables
# Copy this file to .env and fill in your values.

# ============================================================
# Embeddings (Optional — keyword search works without this)
# ============================================================

# OpenAI API key for text-embedding-3-large
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================================
# LLM (Optional — enables query expansion and entity extraction)
# ============================================================

# Anthropic API key for Claude models (used by LLM router)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ============================================================
# Storage
# ============================================================

# PGLite data directory (default: memory:// for in-memory)
# Set to a path like ./pgdata for persistent storage
SHOGUN_DATA_DIR=./pgdata

# ============================================================
# Privacy
# ============================================================

# Enable PII removal before storing data (default: false)
# Detects and redacts: email, credit cards, phone numbers, API keys, etc.
SHOGUN_PII_REMOVAL=false

# ============================================================
# Logging
# ============================================================

# Log level: debug | info | warn | error (default: info)
SHOGUN_LOG_LEVEL=info
